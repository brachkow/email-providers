{
  "name": "@brachkow/email-providers",
  "version": "1.2.0",
  "description": "URLs of popular email providers as JS object",
  "main": "index.js",
  "files": [
    "index.js",
    "index.d.ts",
    "index.d.ts.map"
  ],
  "scripts": {
    "build": "tsc",
    "prepack": "tsc",
    "prepublishOnly": "pnpm test && pnpm typecheck",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "validate:urls": "node scripts/generate-hurl.mjs > providers.hurl && hurl --test --continue-on-error --connect-timeout 15 --max-time 30 providers.hurl"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/brachkow/email-providers.git"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "author": "Timur Brachkow",
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.1.6",
    "vitest": "^4.1.10"
  }
}
